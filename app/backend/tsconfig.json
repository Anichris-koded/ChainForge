{  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    // Pin the rootDir so ts-jest can compile single spec files located
    // under `__tests__` subdirs without triggering TS5011 (their inferred
    // common root otherwise collapses to the `__tests__` folder).
    "rootDir": "./",
    "paths": {
      "src/*": ["src/*"]
    },
    "typeRoots": ["../../node_modules/@types", "./node_modules/@types"]
  }
}
